<!DOCTYPE html>
<html lang="es">

{%- include "partials/head.njk" -%}

<body>

{%- include "partials/header.njk" -%}

<main id="main" class="container">
    <article>
        {% if image %}
        <img src="{{ image }}" alt="{{ title }}">
        {% endif %}

        {{ content | safe }}

        {% if qr %}
        <img src="{{ qr }}" alt="Código QR del post {{ title }}">
        {% endif %}
    </article>
</main>

{%- include "partials/footer.njk" -%}

</body>
</html>
